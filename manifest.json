{
  "manifest_version": 3,
  "name": "GCal Toggle Declined Events",
  "version": "1.0.0",
  "description": "One-click toggle for 'Show declined events' in Google Calendar",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://calendar.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle declined events",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
